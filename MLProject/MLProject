name: customer-churn-prediction-system

python_env: MLProject/conda.yaml

entry_points:
  main:
    parameters:
      train_path:
        type: str
        default: "MLProject/telco_preprocessing/train_pca.csv"
      test_path:
        type: str
        default: "MLProject/telco_preprocessing/train_pca.csv"
      target_col:
        type: str
        default: "Churn Label"
      n_iter:
        type: float
        default: 25
      n_splits:
        type: float
        default: 25
      random_state:
        type: float
        default: 126

    command: >
      python MLProject/modelling.py
        --train_path {train_path}
        --test_path {test_path}
        --target_col {target_col}
        --n_iter {n_iter}
        --n_splits {n_splits}
        --random_state {random_state} 
